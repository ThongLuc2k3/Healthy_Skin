PORT=4000
# Tạo chuỗi ngẫu nhiên dài, KHÔNG dùng giá trị mẫu này: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Gemini API key (miễn phí, không cần thẻ thanh toán) — tạo tại https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

DB_PATH=./data/da_duong.sqlite
CORS_ORIGIN=http://localhost:5173
